# 依赖
node_modules/

# 前端构建产物(go:embed 前由 vite build 生成)
dist/

# Go 编译产物(单二进制)
/console/mooncell
/console/console
/agent/agent
*.exe

# 发布打包产物(由 deploy/build-release.sh 生成)
/deploy/release/

# SQLite 运行期文件
*.db
*.db-shm
*.db-wal

# Agent 本地状态
/agent/data/

# Agent 升级包(运行期上传,按架构存储)
/console/agentbin/

# 日志与杂项
*.log
.DS_Store

# IDE
.idea/
