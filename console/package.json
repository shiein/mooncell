{
  "name": "mooncell-console",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Mooncell 内网自动化部署平台控制台 — Vite + React + Tailwind 前端,Go 后端(单二进制)",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"go run .\"",
    "dev:web": "vite",
    "dev:api": "go run .",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && go build -o mooncell .",
    "test:e2e": "sh e2e/run-e2e.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  }
}
